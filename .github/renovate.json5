{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  dependencyDashboard: true,
  configMigration: true,
  timezone: "America/Los_Angeles",
  assignees: ["@emmercm"],
  reviewers: ["@emmercm"],
  assignAutomerge: false,
  vulnerabilityAlerts: {
    labels: ["security"],
    platformAutomerge: true,
    groupName: "",
    schedule: [],
    dependencyDashboardApproval: false,
    minimumReleaseAge: "",
    rangeStrategy: "update-lockfile",
    commitMessageSuffix: "[SECURITY]",
    branchTopic: "{{{datasource}}}-{{{depName}}}-vulnerability",
    prCreation: "immediate",
  },
  commitMessagePrefix: "Chore:",
  commitMessageAction: "update",
  separateMultipleMajor: true,
  separateMajorMinor: true,
  separateMinorPatch: false,
  schedule: "on the 27th day of the month",
  prCreation: "immediate",
  prHourlyLimit: 0,
  automerge: true,
  platformAutomerge: true,
  rebaseWhen: "never",
  rebaseLabel: "renovate/rebase",
  updateNotScheduled: true,
  rangeStrategy: "pin",
  minimumReleaseAge: "7 days",
  internalChecksFilter: "strict",
  packageRules: [
    {
      matchPackageNames: ["node"],
      groupName: "Node.js",
      allowedVersions: "/^v?\\d*[02468]\\./",
      ignoreUnstable: false,
      minimumReleaseAge: "5 days",
      schedule: "at any time",
    },
    {
      matchPackageNames: ["bun"],
      groupName: "Bun",
      minimumReleaseAge: "0 days",
      schedule: "at any time",
    },
    {
      matchFileNames: ["docs/**"],
      groupName: "docs dependencies",
    },
    {
      matchUpdateTypes: ["pin", "pinDigest"],
      commitMessageAction: "pin",
      groupName: "version ranges",
      schedule: "at any time",
      recreateWhen: "always",
    },
    {
      matchUpdateTypes: ["rollback"],
      schedule: "at any time",
      recreateWhen: "always",
    },
    {
      matchUpdateTypes: ["major"],
      schedule: "at any time",
    },
  ],
  "github-actions": {
    packageRules: [
      {
        matchDepNames: ["python"],
        enabled: false,
      },
      {
        matchDepTypes: ["action"],
        pinDigests: true,
        extractVersion: "^(?<version>v?\\d+\\.\\d+\\.\\d+)$",
        versioning: "regex:^v?(?<major>\\d+)(\\.(?<minor>\\d+)\\.(?<patch>\\d+))?$",
      },
      {
        matchDepTypes: ["action"],
        matchUpdateTypes: ["major"],
        automerge: false,
      },
      {
        matchDepTypes: ["action"],
        matchUpdateTypes: ["patch", "minor"],
        groupName: "GitHub Actions",
        schedule: "on the 26th day of the month",
      },
    ],
  },
  npm: {
    lockFileMaintenance: {
      enabled: true,
      schedule: "on the 28th day of the month",
      commitMessageAction: "update",
      commitMessageTopic: "lockfile",
    },
    packageRules: [
      {
        groupName: "dependencies",
        matchDepTypes: ["dependencies", "devDependencies"],
        matchUpdateTypes: ["patch", "minor"],
      },
      {
        matchDepTypes: ["dependencies", "devDependencies"],
        constraintsFiltering: "strict",
        rollbackPrs: true,
        rollback: {
          prPriority: -10,
        },
      },
      {
        groupName: null,
        matchPackageNames: ["chdman", "dolphin-tool", "maxcso"],
        schedule: "at any time",
        minimumReleaseAge: "0 hours",
      },
      {
        groupName: "dev dependencies",
        matchDepTypes: ["devDependencies"],
        matchUpdateTypes: ["patch", "minor"],
        matchPackageNames: [
          "!@types/async",
          "!@types/cli-progress",
          "!@types/micromatch",
          "!@types/semver",
          "!@types/xml2js",
          "!@types/yargs",
        ],
      },
      {
        groupName: "ESLint",
        matchUpdateTypes: ["patch", "minor"],
        matchPackageNames: [
          "/typescript-eslint/",
          "/^@typescript-eslint/",
          "/^eslint/",
          "//eslint/",
        ],
      },
      {
        matchUpdateTypes: ["major"],
        minimumReleaseAge: "14 days",
        matchPackageNames: ["/eslint/"],
      },
      {
        matchUpdateTypes: ["major", "minor"],
        schedule: "at any time",
        matchPackageNames: ["/typescript-eslint/", "/^@typescript-eslint//"],
      },
      {
        matchPackageNames: ["typescript"],
        groupName: "TypeScript",
        prPriority: -20,
        schedule: "at any time",
      },
      {
        matchDepTypes: ["optionalDependencies", "peerDependencies", "engines"],
        enabled: false,
      },
    ],
  },
}
